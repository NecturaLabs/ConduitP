# Conduit secrets — copy to .env and fill in values,
# or run ./scripts/generate-secrets.sh to generate automatically.
JWT_SECRET=
JWT_REFRESH_SECRET=
CONDUIT_HOOK_TOKEN=

# Frontend — injected by Netlify (or your CI) at build time.
# Set this in your Netlify site environment variables, not in a committed file.
VITE_API_URL=

# Android App Links — injected by GitHub Actions at build time via -PCONDUIT_API_HOST.
# Set CONDUIT_API_HOST as a GitHub Actions repository variable (vars.CONDUIT_API_HOST).
# This must be the hostname only (no scheme), e.g. conduit-api.example.com
CONDUIT_API_HOST=
